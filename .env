# ============================================================
# .env — Configuration du frontend Factur-X 2026
# Ce fichier est chargé automatiquement par react-scripts.
#
# IMPORTANT :
# — Ne jamais commiter ce fichier dans Git si vous y mettez
#   des clés secrètes ou des mots de passe.
# — Toutes les variables DOIVENT commencer par REACT_APP_
#   pour être accessibles dans le code React.
# — Après modification de ce fichier, relancer npm start.
# ============================================================


# ============================================================
# URL DE BASE DE L'API BACKEND ASP.NET CORE
# ============================================================

# Option A (recommandée en développement) :
# Laisser VIDE pour utiliser le proxy configuré dans package.json.
# Le proxy redirige automatiquement /api/* vers https://localhost:5001
# Avantage : pas de problème CORS en développement.
REACT_APP_API_URL=

# Option B — HTTP sans certificat (si le certificat HTTPS pose problème) :
# Décommentez cette ligne et commentez la ligne ci-dessus.
# Le backend doit alors écouter sur http://localhost:5000
# (configuré dans appsettings.Development.json)
# REACT_APP_API_URL=http://localhost:5000

# Option C — HTTPS avec certificat auto-signé ASP.NET Core :
# Décommentez si vous avez exécuté : dotnet dev-certs https --trust
# REACT_APP_API_URL=https://localhost:5001


# ============================================================
# PARAMÈTRES DU SERVEUR DE DÉVELOPPEMENT REACT
# ============================================================

# Désactive l'ouverture automatique du navigateur au démarrage
BROWSER=none

# Port du serveur de développement React (défaut : 3000)
# PORT=3000

# Désactive HTTPS pour le serveur React de développement.
# Mettre true uniquement si vous avez un certificat SSL valide.
# HTTPS=false


# ============================================================
# PARAMÈTRES DE L'APPLICATION
# ============================================================

# Nom de l'application (affiché dans l'interface)
REACT_APP_NOM_APPLICATION=Factur-X 2026

# Version de l'application
REACT_APP_VERSION=1.0.0

# Environnement (development | production | test)
# Cette variable est gérée automatiquement par react-scripts.
# Ne pas la modifier ici.
# NODE_ENV=development


# ============================================================
# CONFIGURATION FACTUR-X
# ============================================================

# Identifiant PDP par défaut (Portail Public de Facturation)
# Remplacer par votre identifiant PDP réel obtenu auprès de la DGFiP
REACT_APP_PDP_ID_DEFAUT=PDP-001

# Nom du PDP par défaut
REACT_APP_PDP_NOM_DEFAUT=Chorus Pro

# Taux de pénalités de retard par défaut (%/an)
# Conformément à l'art. L441-10 C.com. : minimum 3× taux intérêt légal
REACT_APP_TAUX_PENALITES_DEFAUT=15

# Indemnité forfaitaire de recouvrement par défaut (€)
# Minimum légal : 40€ (art. D441-5 C.com.)
REACT_APP_INDEMNITE_RECOUVREMENT_DEFAUT=40